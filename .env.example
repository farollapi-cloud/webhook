# Copie para .env e ajuste (não commite segredos reais).
ENVIRONMENT=development
LOG_LEVEL=INFO

# URL pública do backend (usada na montagem da URL do webhook).
BACKEND_PUBLIC_URL=http://localhost:8000

# PostgreSQL em produção/dev local (ex.: docker-compose).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/webhook_saas

# JWT e credenciais da API de gestão (obter token em POST /api/v1/auth/token).
SECRET_KEY=gere-com-openssl-rand-hex-32
AUTH_CLIENT_ID=admin
AUTH_CLIENT_SECRET=altere-este-segredo

# Limite de body no endpoint público de webhook (bytes).
WEBHOOK_MAX_BODY_BYTES=524288

# Origens CORS para o frontend (SPA), separadas por vírgula.
# Ex.: https://seu-static.onrender.com
CORS_ORIGINS=http://localhost:5173
